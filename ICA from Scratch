print("\n" + "="*50)
print("STEP 1: CENTERING THE DATA")
print("="*50)
print("Mean of each column:", mean)
print("Centered Data (X - mean):")
print(centered_data)

print("\n" + "="*50)
print("STEP 2: COVARIANCE MATRIX")
print("="*50)
print("Covariance Matrix:")
print(cov_matrix)

