print("Eigenvectors:")
print(eigenvectors)

print("\n" + "="*50)
print("STEP 4: ADD EPSILON FOR SAFETY")
print("="*50)
print("Eigenvalues after adding epsilon:")
print(eigenvalues_safe)

print("\n" + "="*50)
print("STEP 5: WHITENING THE DATA")
print("="*50)
print("Whitening Matrix:")
print(whitening_matrix)
print("Whitened Data:")
print(whitened_data)

print("\n" + "="*50)
print("STEP 6 & 7: INITIALIZE RANDOM WEIGHTS")
print("="*50)
print("Initial Random Weight Matrix (Before QR):")
print(W)

print("\n" + "="*50)
print("STEP 8: ORTHONORMALIZE INITIAL WEIGHTS (QR DECOMPOSITION)")
print("="*50)
print("Weight Matrix after QR:")
print(W)

print("\n" + "="*50)
print("STEP 9: ICA ITERATION LOOP")
print("="*50)

print("\n" + "="*50)
